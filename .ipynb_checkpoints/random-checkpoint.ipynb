   "source": [
    "lower = int(input('Enter lower Range'))\n",
    "upper = int(input('Enter upper range'))\n",
    "\n",
    "for i in range(lower,upper+1):\n",
    "    for j in range(2,i):\n",
    "        if i%j == 0 :\n",
    "            break \n",
    "    else :\n",
    "            print(i)"
